# Copy this file to .env on the live server and update real values there.

APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Dhaka

PUBLIC_BASE_URL=https://colorpolytech.com
ADMIN_BASE_URL=https://admin.colorpolytech.com
OFFICE_BASE_URL=https://office.colorpolytech.com

# Website/Admin database
CP_DB_HOST=localhost
CP_DB_NAME=colojmbr_cp
CP_DB_USER=your_cp_db_user
CP_DB_PASS=your_cp_db_password
CP_DB_CHARSET=utf8mb4

# Office ERP database
OFFICE_DB_HOST=localhost
OFFICE_DB_NAME=colojmbr_office
OFFICE_DB_USER=your_office_db_user
OFFICE_DB_PASS=your_office_db_password
OFFICE_DB_CHARSET=utf8mb4

# Optional SMS API - never commit real credentials
SMS_API_URL=https://sms.fastsmsbd.com/api
SMS_API_LOGIN_ID=your_login_id
SMS_API_PASSWORD=your_password
